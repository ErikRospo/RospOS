.SEG 0xFFFF0000
_START:
    // Initialize registers
    ADDI r1, r0, 10  // n = 10
    ADDI r2, r0, 0   // a = 0
    ADDI r3, r0, 1   // b = 1
    ADDI r4, r0, 1   // i = 1

JMP LOOP

TTY_ADDR: // It is the responsibility of code to know how how long the address is, and to use LW/LH/LB appropriately
    .DATA 0x1000_0000
HELLO_WORLD:
    .STR "Hello, World!\n"
NEWLINE:
    .STR "\n"
RAND_DATA:
    .RAND 4 // 4 bytes of random data
.SEG 0x00000000

LOOP:
    ADD r5, r2, r3 // c = a + b
    ADD r2, r3, r0 // a = b
    ADD r3, r5, r0 // b = c
    ADDI r4, r4, 1 // i++
    BLT r4, r1, LOOP // if i < n, repeat

//r5 now contains the nth Fibonacci number
ADDI r1, r5, 0 // Move result to r1 for printing

CALL PRINT_NUMBER // Print the Fibonacci number
ADDI r1, r0, NEWLINE
CALL PRINT_STRING // Print newline

ADDI r1, r0, HELLO_WORLD
CALL PRINT_STRING // Print "Hello, World!\n"

ADDI r2, r0, RAND_DATA
LW r1, r2, 0 // Load random data 
CALL PRINT_NUMBER 

BREAK
.INC "common_functions.ros"