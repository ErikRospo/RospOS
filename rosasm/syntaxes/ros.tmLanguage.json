{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "RospOS Assembly",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#labels"
		},
		{
			"include": "#directives"
		},
		{
			"include": "#instructions"
		},
		{
			"include": "#registers"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#strings"
		}
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.line.double-slash.ros",
					"match": "//.*$"
				},
				{
					"name": "comment.block.ros",
					"begin": "/\\*",
					"end": "\\*/"
				}
			]
		},
		"labels": {
			"patterns": [
				{
					"name": "entity.name.tag.ros",
					"match": "[a-zA-Z_][a-zA-Z0-9_]*(?=:)"
				}
			]
		},
		"directives": {
			"patterns": [
				{
					"name": "meta.directive.ros",
					"match": "\\.(SEG|DATA|STR|FUNC|INC|RAND|SPACE)\\b",
					"captures": {
						"1": {
							"name": "keyword.directive.ros"
						}
					}
				}
			]
		},
		"instructions": {
			"patterns": [
				{
					"name": "keyword.instruction.rtype.ros",
					"match": "\\b(ADD|SUB|AND|OR|XOR|MUL|MULH|SHL|SHR|SAR|DIV|DIVU|REM|REMU)\\b"
				},
				{
					"name": "keyword.instruction.itype.ros",
					"match": "\\b(ADDI|ANDI|ORI|XORI|SHLI|SHRI|SARI)\\b"
				},
				{
					"name": "keyword.instruction.lstype.ros",
					"match": "\\b(LB|LBU|LH|LHU|LW|SB|SH|SW)\\b"
				},
				{
					"name": "keyword.instruction.btype.ros",
					"match": "\\b(BEQ|BNE|BLT|BGE|BLTU|BGEU)\\b"
				},
				{
					"name": "keyword.instruction.jtype.ros",
					"match": "\\b(JAL|JALR)\\b"
				},
				{
					"name": "keyword.instruction.system.ros",
					"match": "\\b(ECALL|BREAK|NOP)\\b"
				},
				{
					"name": "keyword.instruction.pseudo.ros",
					"match": "\\b(PUSH|POP|LLI|JMP|CALL|RET|SUBI|MULI|DIVI|REMI|MOV|ZERO|NOT|NEG)\\b"
				}
			]
		},
		"registers": {
			"patterns": [
				{
					"name": "constant.register.ros",
					"match": "\\b(r(1[0-5]|[0-9])|SP|LR|FP)\\b"
				}
			]
		},
		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.hex.ros",
					"match": "0x[0-9a-fA-F_]+"
				},
				{
					"name": "constant.numeric.binary.ros",
					"match": "0b[01_]+"
				},
				{
					"name": "constant.numeric.decimal.ros",
					"match": "-?[0-9][0-9_]*\\b"
				}
			]
		},
		"strings": {
			"name": "string.quoted.double.ros",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.ros",
					"match": "\\\\."
				}
			]
		}
	},
	"scopeName": "source.ros"
}