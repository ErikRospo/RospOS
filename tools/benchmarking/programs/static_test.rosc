
inline int add(int a, int b)
{
    return a + b;
}

void print_string(char *str)
{
    int tty_addr = 0x10000000;
    while (*str)
    {
        __sb(tty_addr, *str);
        str++;
    }
}
inline void print_char(char c)
{
    int tty_addr = 0x10000000;
    __sb(tty_addr, c);
}

char *font_address = __embed("font_bitmap.bin");

void draw_char_to_display(int ch, int x, int y, int color)
{
    int glyph = ch * 8;
    int row = 0;
    while (row < 8)
    {
        int glyph_row = __lb(font_address + glyph + row);
        int col = 0;
        while (col < 8)
        {
            int bit = (glyph_row >> col) & 1;
            if (bit)
            {
                int px = x + col;
                int py = y + row;
                int index = (py * 256) + px;
                __sb(0x20000000 + index, color);
            }
            col = col + 1;
        }
        row = row + 1;
    }
    return;
}

void draw_string_to_display(char *str, int x, int y, int color)
{
    while (*str)
    {
        draw_char_to_display(*str, x, y, color);
        str = str + 1;
        x = x + 8;
    }
    return;
}
void main()
{
    int r1= add(15, 25);
    inline int r2 = 50;
    int r3 = add(r1, r2);
    //r3 should be 90, which is ascii for 'Z'
    char buffer[8];
    buffer[0] = r3; // Store the result in the buffer as a character
    buffer[1] = '\0'; // Null-terminate the string
    draw_string_to_display("The result of add(15, 25) + 50 as a character: ", 10, 10, 0x3F);
    draw_string_to_display(buffer, 10, 30, 0x3F);
    print_string("The result of add(15, 25) + 50 as a character on the TTY: ");
    print_string(buffer);
    draw_string_to_display("Hello, RospOS!", 10, 70, 0x3F);
    draw_string_to_display("Green RospOS", 10, 90 , 0x0C);
    draw_string_to_display("Red RospOS", 10, 110 , 0x30);
    draw_string_to_display("Blue RospOS", 10, 130 , 0x07);
    draw_string_to_display("Yellow RospOS", 10, 150 , 0x3C);
    return;
}