// .rosc translation of binaries/screen_test.ros
int steplfsr(int lfsr)
{
    int bit = ((lfsr >> 0) ^ (lfsr >> 2) ^ (lfsr >> 3) ^ (lfsr >> 5)) & 1;
    return (lfsr >> 1) | (bit << 15);
}
void screen_test()
{
    int addr = 0x20000000;
    int remaining = 0x00010000;
    int lfsr = 0xDEADBEEF;

    while (remaining)
    {
        __sb(addr, lfsr);
        addr = addr + 1;
        
        for (int i = 0; i < 16; i++)
        {
            lfsr = steplfsr(lfsr);
        }
        remaining = remaining - 1;
    }
}
