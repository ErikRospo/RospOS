#include <stdio.rosc>

// .rosc translation of tty.ros helpers.
char read_line(char *buffer, int max_len)
{
    int i = 0;
    while (i < max_len - 1)
    {
        char c = read_char();
        if (c == 0x0A)
        {
            break;
        }
        buffer[i] = c;
        i = i + 1;
    }
    buffer[i] = 0;
    return i;
}
