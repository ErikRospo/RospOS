void rand_block_test(){
    char buffer[512];
    int addr = 0x20000000;
    int remaining = 0x00010000;
    int blockID=0xFFFFFFFE;
    while (remaining)
    {
        read_block(blockID, buffer);
        for (int i = 0; i < 512; i++)
        {
            __sb(addr, buffer[i]);
            addr = addr + 1;
        }
        blockID = blockID - 1;
        remaining = remaining - 512;
    }
    return;
}