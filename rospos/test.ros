.SEG 0xFFFF_FFFC
    .DATA 0x0000_0000 // Reset vector points to address 0x00000000
.SEG 0x00000000
MAIN:
    ADDI r1, r0, 6  // n = 6
    ADDI r2, r0, 0   // a = 0
    ADDI r3, r0, 1   // b = 1
    ADDI r4, r0, 1   // i = 1

LOOP:
    ADD r5, r2, r3 // c = a + b
    ADDI r2, r3, 0 // a = b
    ADDI r3, r5, 0 // b = c
    ADDI r4, r4, 1 // i++
    BLT r4, r1, LOOP // if i < n, repeat

//r5 now contains the nth Fibonacci number
ADDI r1, r5, 0 // Move result to r1 for printing

CALL PRINT_NUMBER // Print the Fibonacci number
ADDI r1, r0, NEWLINE
CALL PRINT_STRING // Print newline

ADDI r1, r0, HELLO_WORLD
CALL PRINT_STRING // Print "Hello, World!\n"

ADDI r2, r0, RAND_DATA
LW r1, r2, 0 // Load random data 
CALL PRINT_NUMBER 

BREAK
.INC "common_functions.ros"

.SEG 0x0000_1000
HELLO_WORLD:
    .STR "Hello, World!\n"
NEWLINE:
    .STR "\n"
RAND_DATA:
    .DATA 0x1234_5678 // Example random data to keep the program deterministic for testing
    //.RAND 4 // 4 bytes of random data