3922 rospos/build/rospos_preprocessed.rosc 1140 "    struct fixed_point fp2 = int_to_fixed_point(10);"
3923 rospos/build/rospos_preprocessed.rosc 1141 "    struct fixed_point half = fixed_point_from_parts(0, 0x80000000); // 0.5 in 32.32 fixed-point representation"
3924 rospos/build/rospos_preprocessed.rosc 1142 "    struct fixed_point sum = add_fixed_point_with_int(fp1, 3); // Should be 8.0 in fixed-point"
3925 rospos/build/rospos_preprocessed.rosc 1143 "    struct fixed_point product = multiply_fixed_point_with_int(fp2, 4); // Should be 40.0 in fixed-point"
3926 rospos/build/rospos_preprocessed.rosc 1144 "    struct fixed_point half_sum = multiply_fixed_point(sum, half);"
3927 rospos/build/rospos_preprocessed.rosc 1145 "    struct fixed_point total = add_fixed_point(product, half_sum);"
