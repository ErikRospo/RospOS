  RET

.FUNC main:
  PUSH r14
  // emit call to draw_string_to_display with args [{'type': 'string_addr', 'label': 'str_3'}, {'type': 'const', 'value': 10}, {'type': 'const', 'value': 10}]
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
  LLI r1, str_3    // load immediate str_3
  LLI r2, 10    // load immediate 10
  LLI r3, 10    // load immediate 10
  CALL draw_string_to_display
  // call return value in r1
  POP r1  
  // emit call to draw_line with args [{'type': 'const', 'value': 20}, {'type': 'const', 'value': 50}, {'type': 'const', 'value': 30}, {'type': 'const', 'value': 60}]
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
  LLI r1, 20    // load immediate 20
  LLI r2, 50    // load immediate 50
  LLI r3, 30    // load immediate 30
  LLI r4, 60    // load immediate 60
  CALL draw_line
  // call return value in r1
  POP r1  
  // emit call to draw_rectangle with args [{'type': 'const', 'value': 100}, {'type': 'const', 'value': 100}, {'type': 'const', 'value': 150}, {'type': 'const', 'value': 100}]
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
  LLI r1, 100    // load immediate 100
  LLI r2, 100    // load immediate 100
  LLI r3, 150    // load immediate 150
  LLI r4, 100    // load immediate 100
  CALL draw_rectangle
  // call return value in r1
  POP r1  
  // epilogue and return
  ADDI r1, r0, 0  // ensure r1=0
  BREAK    // exit from main


