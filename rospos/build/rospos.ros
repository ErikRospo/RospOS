.FUNC draw_rectangle:
  PUSH r14
  // emit call to draw_horizontal_line with args [{'type': 'var', 'name': 'x'}, {'type': 'var', 'name': 'y'}, {'type': 'var', 'name': 'width'}]
  PUSH r2    // save caller temp
  PUSH r3    // save caller temp
  PUSH r4    // save caller temp
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
  ADDI r1, r1, 0    // move arg 0
  ADDI r2, r2, 0    // move arg 1
  ADDI r3, r3, 0    // move arg 2
  CALL draw_horizontal_line
  // call return value in r1
  POP r1  
  POP r4    // restore caller temp
  POP r3    // restore caller temp
  POP r2    // restore caller temp
  // emit call to draw_horizontal_line with args [{'type': 'var', 'name': 'x'}, {'type': 'binop', 'op': 'minus', 'left': {'type': 'binop', 'op': 'plus', 'left': {'type': 'var', 'name': 'y'}, 'right': {'type': 'var', 'name': 'height'}}, 'right': {'type': 'const', 'value': 1}}, {'type': 'var', 'name': 'width'}]
  PUSH r2    // save caller temp
  PUSH r3    // save caller temp
  PUSH r4    // save caller temp
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
  ADDI r1, r1, 0    // move arg 0
  ADD r5, r2, r4    // binop +
  LLI r6, 1    // load immediate 1
  SUB r5, r5, r6    // binop -
  ADDI r2, r5, 0    // move arg 1 from expr
  ADDI r3, r3, 0    // move arg 2
  CALL draw_horizontal_line
  // call return value in r1
  POP r1  
  POP r4    // restore caller temp
  POP r3    // restore caller temp
  POP r2    // restore caller temp
  // emit call to draw_vertical_line with args [{'type': 'var', 'name': 'x'}, {'type': 'var', 'name': 'y'}, {'type': 'var', 'name': 'height'}]
  PUSH r2    // save caller temp
  PUSH r3    // save caller temp
  PUSH r4    // save caller temp
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
  ADDI r1, r1, 0    // move arg 0
  ADDI r2, r2, 0    // move arg 1
  ADDI r3, r4, 0    // move arg 2
  CALL draw_vertical_line
  // call return value in r1
  POP r1  
  POP r4    // restore caller temp
  POP r3    // restore caller temp
  POP r2    // restore caller temp
  // emit call to draw_vertical_line with args [{'type': 'binop', 'op': 'minus', 'left': {'type': 'binop', 'op': 'plus', 'left': {'type': 'var', 'name': 'x'}, 'right': {'type': 'var', 'name': 'width'}}, 'right': {'type': 'const', 'value': 1}}, {'type': 'var', 'name': 'y'}, {'type': 'var', 'name': 'height'}]
  PUSH r2    // save caller temp
  PUSH r3    // save caller temp
  PUSH r4    // save caller temp
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
  ADD r7, r1, r3    // binop +
  LLI r8, 1    // load immediate 1
  SUB r7, r7, r8    // binop -
  ADDI r1, r7, 0    // move arg 0 from expr
  ADDI r2, r2, 0    // move arg 1
  ADDI r3, r4, 0    // move arg 2
  CALL draw_vertical_line
  // call return value in r1
  POP r1  
  POP r4    // restore caller temp
  POP r3    // restore caller temp
  POP r2    // restore caller temp
  // epilogue and return
  ADDI r1, r0, 0  // ensure r1=0
  POP r14
  RET

.FUNC screen_test:
  PUSH r14
  LLI r2, 536870912    // init addr
  LLI r3, 65536    // init remaining
  LLI r4, 3735928559    // init lfsr
WHILE126:
  BEQ r3, r0, WHILE_END127
  SB r4, r2, 0    // intrinsic __sb
  LLI r5, 0    // zero init addr
  LLI r6, 1    // load immediate 1
  ADD r6, r5, r6    // binop +
  ADDI r2, r6, 0    // assign addr
  LLI r7, 0    // zero init bit
  LLI r8, 0    // load immediate 0
  SHR r8, r4, r8    // binop >>
  LLI r9, 2    // load immediate 2
  SHR r9, r4, r9    // binop >>
  XOR r8, r8, r9    // binop ^
  LLI r10, 3    // load immediate 3
  SHR r10, r4, r10    // binop >>
  XOR r8, r8, r10    // binop ^
  LLI r11, 5    // load immediate 5
  SHR r11, r4, r11    // binop >>
  XOR r8, r8, r11    // binop ^
  LLI r12, 1    // load immediate 1
  AND r8, r8, r12    // binop &
  ADDI r7, r8, 0    // init bit from expr
  LLI r6, 1    // load immediate 1
  SHR r6, r4, r6    // binop >>
  LLI r9, 15    // load immediate 15
  SHL r9, r7, r9    // binop <<
  OR r6, r6, r9    // binop |
  ADDI r4, r6, 0    // assign lfsr
  LLI r10, 0    // zero init remaining
  LLI r11, 1    // load immediate 1
  SUB r11, r10, r11    // binop -
  ADDI r3, r11, 0    // assign remaining
  JMP WHILE126
WHILE_END127:
  // epilogue and return
  ADDI r1, r0, 0  // ensure r1=0
  POP r14
  RET

.FUNC add_coords:
  PUSH r14
  LW r2, r1, 0    // load p.x
  LW r3, r1, 4    // load p.y
  ADD r2, r2, r3    // binop +
  ADD r1, r2, r0
  POP r14
  RET

.FUNC add:
  PUSH r14
  ADD r3, r1, r2    // binop +
  ADD r1, r3, r0
  POP r14
  RET

.FUNC old_main:
  PUSH r14
  LLI r2, 5    // init x
  LLI r3, 10    // init y
  LLI r4, 0    // zero init result
  // emit call to add with args [{'type': 'var', 'name': 'x'}, {'type': 'var', 'name': 'y'}]
  PUSH r2    // save caller temp
  PUSH r3    // save caller temp
  PUSH r4    // save caller temp
  ADDI r1, r2, 0    // move arg 0
  ADDI r2, r3, 0    // move arg 1
  CALL add
  // call return value in r1
  POP r4    // restore caller temp
  POP r3    // restore caller temp
  POP r2    // restore caller temp
  ADDI r4, r1, 0    // move return value
  // emit call to print_string with args [{'type': 'string_addr', 'label': 'str_0'}]
  PUSH r2    // save caller temp
  PUSH r3    // save caller temp
  PUSH r4    // save caller temp
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
  LLI r1, str_0    // load immediate str_0
  CALL print_string
  // call return value in r1
  POP r1  
  POP r4    // restore caller temp
  POP r3    // restore caller temp
  POP r2    // restore caller temp
  // emit call to printi with args [{'type': 'var', 'name': 'result'}]
  PUSH r2    // save caller temp
  PUSH r3    // save caller temp
  PUSH r4    // save caller temp
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
  ADDI r1, r4, 0    // move arg 0
  CALL printi
  // call return value in r1
  POP r1  
  POP r4    // restore caller temp
  POP r3    // restore caller temp
  POP r2    // restore caller temp
  LLI r5, p1_struct128    // init p1 (struct Point addr)
  LLI r6, s_struct129    // init s (struct Size addr)
  LLI r7, 10    // load immediate 10
  SW r7, r5, 0    // store p1.x
  LLI r8, 20    // load immediate 20
  SW r8, r5, 4    // store p1.y
  LLI r9, 640    // load immediate 640
  SW r9, r6, 0    // store s.width
  LLI r10, 480    // load immediate 480
  SW r10, r6, 4    // store s.height
  LLI r11, 0    // zero init sum
  // emit call to add_coords with args [{'type': 'var', 'name': 'p1'}]
  PUSH r2    // save caller temp
  PUSH r3    // save caller temp
  PUSH r4    // save caller temp
  PUSH r5    // save caller temp
  PUSH r6    // save caller temp
  PUSH r11    // save caller temp
  ADDI r1, r5, 0    // move arg 0
  CALL add_coords
  // call return value in r1
  POP r11    // restore caller temp
  POP r6    // restore caller temp
  POP r5    // restore caller temp
  POP r4    // restore caller temp
  POP r3    // restore caller temp
  POP r2    // restore caller temp
  ADDI r11, r1, 0    // move return value
  LLI r12, 0    // zero init area
  LW r7, r6, 0    // load s.width
  LW r8, r6, 4    // load s.height
  MUL r7, r7, r8    // binop *
  ADDI r12, r7, 0    // init area from expr
  // emit call to print_string with args [{'type': 'string_addr', 'label': 'str_1'}]
  PUSH r2    // save caller temp
  PUSH r3    // save caller temp
  PUSH r4    // save caller temp
  PUSH r5    // save caller temp
  PUSH r6    // save caller temp
  PUSH r11    // save caller temp
  PUSH r12    // save caller temp
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
  LLI r1, str_1    // load immediate str_1
  CALL print_string
  // call return value in r1
  POP r1  
  POP r12    // restore caller temp
  POP r11    // restore caller temp
  POP r6    // restore caller temp
  POP r5    // restore caller temp
  POP r4    // restore caller temp
  POP r3    // restore caller temp
  POP r2    // restore caller temp
  // emit call to printi with args [{'type': 'var', 'name': 'sum'}]
  PUSH r2    // save caller temp
  PUSH r3    // save caller temp
  PUSH r4    // save caller temp
  PUSH r5    // save caller temp
  PUSH r6    // save caller temp
  PUSH r11    // save caller temp
  PUSH r12    // save caller temp
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
  ADDI r1, r11, 0    // move arg 0
  CALL printi
  // call return value in r1
  POP r1  
  POP r12    // restore caller temp
  POP r11    // restore caller temp
  POP r6    // restore caller temp
  POP r5    // restore caller temp
  POP r4    // restore caller temp
  POP r3    // restore caller temp
  POP r2    // restore caller temp
  // emit call to print_string with args [{'type': 'string_addr', 'label': 'str_2'}]
  PUSH r2    // save caller temp
  PUSH r3    // save caller temp
  PUSH r4    // save caller temp
  PUSH r5    // save caller temp
  PUSH r6    // save caller temp
  PUSH r11    // save caller temp
  PUSH r12    // save caller temp
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
