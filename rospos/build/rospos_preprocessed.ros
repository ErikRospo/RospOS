  SB r4, r3, 0    // store 
  LLI r6, 1    // load immediate 1
  LLI r5, 6    // load immediate 6
  ADD r5, r2, r5    // binop +
  SB r6, r5, 0    // store 
  LLI r8, 7    // init i
WHILE121:
