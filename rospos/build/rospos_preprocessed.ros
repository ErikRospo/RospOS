.FUNC write_file:
  PUSH r14
  LLI r2, filename_buf150    // init filename (buffer addr)
  LLI r3, data_buf151    // init data (buffer addr)
  LLI r4, 25    // init file_size
  LLI r5, dir_entry_buf152    // init dir_entry (buffer addr)
  LLI r6, 0    // init i
WHILE153:
  LLI r7, 32    // load immediate 32
  BLT r6, r7, CMP_TRUE155
  LLI r7, 0    // compare false path
  JMP CMP_END156
CMP_TRUE155:
  LLI r7, 1
CMP_END156:
  BEQ r7, r0, WHILE_END154
  ADD r8, r2, r6    // binop +
  LB r8, r8, 0    // deref
  ADD r9, r5, r6    // binop +
  SB r8, r9, 0    // store 
  ADDI r6, r6, 1    // assign i (addi fast path)
  JMP WHILE153
WHILE_END154:
  LLI r10, 24    // load immediate 24
  SHR r10, r4, r10    // binop >>
  LLI r11, 255    // load immediate 255
  AND r10, r10, r11    // binop &
  LLI r12, 32    // load immediate 32
  ADD r12, r5, r12    // binop +
  SB r10, r12, 0    // store 
  LLI r7, 16    // load immediate 16
  SHR r7, r4, r7    // binop >>
  LLI r9, 255    // load immediate 255
  AND r7, r7, r9    // binop &
  LLI r8, 33    // load immediate 33
  ADD r8, r5, r8    // binop +
  SB r7, r8, 0    // store 
  LLI r2, 8    // load immediate 8
  SHR r2, r4, r2    // binop >>
  LLI r6, 255    // load immediate 255
  AND r2, r2, r6    // binop &
  LLI r11, 34    // load immediate 34
  ADD r11, r5, r11    // binop +
  SB r2, r11, 0    // store 
  LLI r12, 255    // load immediate 255
  AND r4, r4, r12    // binop &
  LLI r10, 35    // load immediate 35
  ADD r10, r5, r10    // binop +
  SB r4, r10, 0    // store 
  LLI r9, 2    // init data_block_index
  LLI r8, 24    // load immediate 24
  SHR r8, r9, r8    // binop >>
  LLI r7, 255    // load immediate 255
  AND r8, r8, r7    // binop &
  LLI r6, 36    // load immediate 36
  ADD r6, r5, r6    // binop +
  SB r8, r6, 0    // store 
  LLI r11, 16    // load immediate 16
  SHR r11, r9, r11    // binop >>
  LLI r2, 255    // load immediate 255
  AND r11, r11, r2    // binop &
  LLI r4, 37    // load immediate 37
  ADD r4, r5, r4    // binop +
  SB r11, r4, 0    // store 
  LLI r12, 8    // load immediate 8
  SHR r12, r9, r12    // binop >>
  LLI r10, 255    // load immediate 255
  AND r12, r12, r10    // binop &
  LLI r7, 38    // load immediate 38
  ADD r7, r5, r7    // binop +
  SB r12, r7, 0    // store 
  LLI r6, 255    // load immediate 255
  AND r6, r9, r6    // binop &
  LLI r8, 39    // load immediate 39
  ADD r8, r5, r8    // binop +
  SB r6, r8, 0    // store 
  // emit call to write_block with args [{'type': 'const', 'value': 1}, {'type': 'var', 'name': 'dir_entry'}]
  PUSH r3    // save caller temp
  PUSH r5    // save caller temp
  PUSH r9    // save caller temp
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
  LLI r1, 1    // load immediate 1
  ADDI r2, r5, 0    // move arg 1
  CALL write_block
  // call return value in r1
  POP r1  
  POP r9    // restore caller temp
  POP r5    // restore caller temp
  POP r3    // restore caller temp
  // emit call to write_block with args [{'type': 'var', 'name': 'data_block_index'}, {'type': 'var', 'name': 'data'}]
  PUSH r3    // save caller temp
  PUSH r9    // save caller temp
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
  ADDI r1, r9, 0    // move arg 0
  ADDI r2, r3, 0    // move arg 1
  CALL write_block
  // call return value in r1
  POP r1  
  POP r9    // restore caller temp
  POP r3    // restore caller temp
  // epilogue and return
  ADDI r1, r0, 0  // ensure r1=0
  POP r14
  RET

.FUNC read_file:
  PUSH r14
  LLI r2, dir_entry_buf157    // init dir_entry (buffer addr)
  // emit call to read_block with args [{'type': 'const', 'value': 1}, {'type': 'var', 'name': 'dir_entry'}]
  PUSH r2    // save caller temp
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
  LLI r1, 1    // load immediate 1
  ADDI r2, r2, 0    // move arg 1
  CALL read_block
  // call return value in r1
  POP r1  
  POP r2    // restore caller temp
  LLI r3, filename_buf158    // init filename (buffer addr)
  LLI r4, 0    // init i
WHILE159:
  LLI r5, 32    // load immediate 32
  BLT r4, r5, CMP_TRUE161
  LLI r5, 0    // compare false path
  JMP CMP_END162
CMP_TRUE161:
  LLI r5, 1
CMP_END162:
  BEQ r5, r0, WHILE_END160
  ADD r6, r2, r4    // binop +
  LB r6, r6, 0    // deref
  ADD r7, r3, r4    // binop +
  SB r6, r7, 0    // store 
  ADDI r4, r4, 1    // assign i (addi fast path)
  JMP WHILE159
WHILE_END160:
  LLI r8, 0    // load immediate 0
  LLI r9, 32    // load immediate 32
  ADD r9, r3, r9    // binop +
  SB r8, r9, 0    // store 
  LLI r10, 32    // load immediate 32
  ADD r10, r2, r10    // binop +
  LB r10, r10, 0    // deref
  LLI r11, 24    // load immediate 24
  SHL r10, r10, r11    // binop <<
  LLI r12, 33    // load immediate 33
  ADD r12, r2, r12    // binop +
  LB r12, r12, 0    // deref
  LLI r5, 16    // load immediate 16
  SHL r12, r12, r5    // binop <<
  OR r10, r10, r12    // binop |
  LLI r7, 34    // load immediate 34
  ADD r7, r2, r7    // binop +
  LB r7, r7, 0    // deref
  LLI r6, 8    // load immediate 8
  SHL r7, r7, r6    // binop <<
  OR r10, r10, r7    // binop |
  LLI r4, 35    // load immediate 35
  ADD r4, r2, r4    // binop +
  LB r4, r4, 0    // deref
  OR r10, r10, r4    // binop |
  LLI r9, 36    // load immediate 36
  ADD r9, r2, r9    // binop +
  LB r9, r9, 0    // deref
  LLI r8, 24    // load immediate 24
  SHL r9, r9, r8    // binop <<
  LLI r11, 37    // load immediate 37
  ADD r11, r2, r11    // binop +
  LB r11, r11, 0    // deref
  LLI r5, 16    // load immediate 16
  SHL r11, r11, r5    // binop <<
  OR r9, r9, r11    // binop |
  LLI r12, 38    // load immediate 38
  ADD r12, r2, r12    // binop +
  LB r12, r12, 0    // deref
  LLI r6, 8    // load immediate 8
  SHL r12, r12, r6    // binop <<
  OR r9, r9, r12    // binop |
  LLI r7, 39    // load immediate 39
  ADD r7, r2, r7    // binop +
  LB r7, r7, 0    // deref
  OR r9, r9, r7    // binop |
  LLI r4, data_buf163    // init data (buffer addr)
  // emit call to read_block with args [{'type': 'var', 'name': 'data_block_index'}, {'type': 'var', 'name': 'data'}]
  PUSH r3    // save caller temp
  PUSH r4    // save caller temp
  PUSH r9    // save caller temp
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
  ADDI r1, r9, 0    // move arg 0
  ADDI r2, r4, 0    // move arg 1
  CALL read_block
  // call return value in r1
  POP r1  
  POP r9    // restore caller temp
  POP r4    // restore caller temp
  POP r3    // restore caller temp
  // emit call to draw_string_to_display with args [{'type': 'var', 'name': 'filename'}, {'type': 'const', 'value': 10}, {'type': 'const', 'value': 30}, {'type': 'const', 'value': 63}]
  PUSH r3    // save caller temp
  PUSH r4    // save caller temp
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
  ADDI r1, r3, 0    // move arg 0
  LLI r2, 10    // load immediate 10
  LLI r3, 30    // load immediate 30
  LLI r4, 63    // load immediate 63
  CALL draw_string_to_display
  // call return value in r1
  POP r1  
  POP r4    // restore caller temp
  POP r3    // restore caller temp
  // emit call to draw_string_to_display with args [{'type': 'var', 'name': 'data'}, {'type': 'const', 'value': 10}, {'type': 'const', 'value': 50}, {'type': 'const', 'value': 63}]
  PUSH r4    // save caller temp
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
  ADDI r1, r4, 0    // move arg 0
  LLI r2, 10    // load immediate 10
  LLI r3, 50    // load immediate 50
  LLI r4, 63    // load immediate 63
  CALL draw_string_to_display
  // call return value in r1
  POP r1  
  POP r4    // restore caller temp
  // epilogue and return
  ADDI r1, r0, 0  // ensure r1=0
  POP r14
  RET

// Inline function 'add' skipped (will be inlined at call sites)
.FUNC main:
  PUSH r14
  // emit call to draw_rectangle with args [{'type': 'const', 'value': 20}, {'type': 'const', 'value': 100}, {'type': 'const', 'value': 30}, {'type': 'const', 'value': 20}, {'type': 'const', 'value': 63}, {'type': 'const', 'value': 12}]
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
  LLI r2, 12    // load immediate 12
  PUSH r2    // pass overflow arg on stack
  LLI r3, 63    // load immediate 63
  PUSH r3    // pass overflow arg on stack
  LLI r1, 20    // load immediate 20
  LLI r2, 100    // load immediate 100
  LLI r3, 30    // load immediate 30
  LLI r4, 20    // load immediate 20
  CALL draw_rectangle
  // call return value in r1
  ADDI r15, r15, 8    // discard overflow arg slots
  POP r1  
  LLI r4, 0    // zero init r1
  // inline call to add with args [{'type': 'const', 'value': 15}, {'type': 'const', 'value': 25}]
  // begin inline expansion of add
  LLI r5, 15    // load immediate 15
  LLI r6, 25    // load immediate 25
  ADD r7, r5, r6    // binop +
  ADD r1, r7, r0
  // inline function return (no RET emitted)
  ADDI r4, r1, 0    // move inline return value
  // end inline expansion of add
  LLI r8, 50    // init r2
  LLI r9, 0    // zero init r3
  // inline call to add with args [{'type': 'var', 'name': 'r1'}, {'type': 'var', 'name': 'r2'}]
  // begin inline expansion of add
  ADD r10, r4, r8    // binop +
  ADD r1, r10, r0
  // inline function return (no RET emitted)
  ADDI r9, r1, 0    // move inline return value
  // end inline expansion of add
  // emit call to initialize_filesystem with args []
  PUSH r4    // save caller temp
  PUSH r8    // save caller temp
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
  CALL initialize_filesystem
  // call return value in r1
  POP r1  
  POP r8    // restore caller temp
  POP r4    // restore caller temp
  // emit call to write_file with args []
  PUSH r4    // save caller temp
  PUSH r8    // save caller temp
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
  CALL write_file
  // call return value in r1
  POP r1  
  POP r8    // restore caller temp
  POP r4    // restore caller temp
  LLI r11, device_info_buf164    // init device_info (buffer addr)
  // emit call to read_block with args [{'type': 'const', 'value': 4294967295}, {'type': 'var', 'name': 'device_info'}]
  PUSH r4    // save caller temp
  PUSH r8    // save caller temp
  PUSH r11    // save caller temp
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
  LLI r1, 4294967295    // load immediate 4294967295
  ADDI r2, r11, 0    // move arg 1
  CALL read_block
  // call return value in r1
  POP r1  
  POP r11    // restore caller temp
  POP r8    // restore caller temp
  POP r4    // restore caller temp
  // emit call to draw_string_to_display with args [{'type': 'var', 'name': 'device_info'}, {'type': 'const', 'value': 10}, {'type': 'const', 'value': 10}, {'type': 'const', 'value': 63}]
  PUSH r4    // save caller temp
  PUSH r8    // save caller temp
  PUSH r11    // save caller temp
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
  ADDI r1, r11, 0    // move arg 0
  LLI r2, 10    // load immediate 10
  LLI r3, 10    // load immediate 10
  LLI r4, 63    // load immediate 63
  CALL draw_string_to_display
  // call return value in r1
  POP r1  
  POP r11    // restore caller temp
  POP r8    // restore caller temp
  POP r4    // restore caller temp
  // emit call to read_file with args []
  PUSH r4    // save caller temp
  PUSH r8    // save caller temp
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
  CALL read_file
  // call return value in r1
  POP r1  
  POP r8    // restore caller temp
  POP r4    // restore caller temp
  // emit call to draw_string_to_display with args [{'type': 'string_addr', 'label': 'str_0'}, {'type': 'const', 'value': 10}, {'type': 'const', 'value': 70}, {'type': 'const', 'value': 63}]
  PUSH r4    // save caller temp
  PUSH r8    // save caller temp
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
  LLI r1, str_0    // load immediate str_0
