  LLI r10, 0    // load immediate 0
  ADD r9, r2, r8    // binop +
  SB r10, r9, 0    // store 
  ADDI r8, r8, 1    // assign i (addi fast path)
  JMP WHILE121
WHILE_END122:
  // emit call to write_block with args [{'type': 'const', 'value': 0}, {'type': 'var', 'name': 'superblock'}]
  PUSH r2    // save caller temp
  PUSH r1    // If we don't care about the return value, we still need to ensure r1 doesn't get clobbered
  LLI r1, 0    // load immediate 0
  ADDI r2, r2, 0    // move arg 1
  CALL write_block
  // call return value in r1
  POP r1  
  POP r2    // restore caller temp
  // epilogue and return
  ADDI r1, r0, 0  // ensure r1=0
  POP r14
  RET

